" Need to push the rest of vimrc, but so I don't forget:
" Another plugin I want to try out: nerdtree

" for getting the defaults:
source $VIMRUNTIME/defaults.vim

set relativenumber
set ruler

sytax on
colo slate
set tabstop=4
set shiftwidth=4
set autoindent
set smartindent

" set cindent
" set cinkeys-=0#
" set indentkeys-=0#
